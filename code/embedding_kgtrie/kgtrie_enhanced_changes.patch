+def dfs_limited(graph, start_node_list, max_length, max_paths):
+    """
+    Find paths within max_length starting from start_node_list, stopping once
+    max_paths paths have been collected. This is useful for high-hop ablations
+    where exhaustive DFS can explode combinatorially.
+    """
+    if max_paths is None or max_paths <= 0:
+        return dfs(graph, start_node_list, max_length)
+
+    path_lists = []
+    seen = set()
+
+    def add_path(path):
+        key = tuple(path)
+        if key not in seen:
+            seen.add(key)
+            path_lists.append(key)
+
+    def dfs_visit(node, path):
+        if len(path_lists) >= max_paths or len(path) > max_length:
